# name: test/sql/band_math.test
# description: ST_BandMath (5 ops + alias forms + unknown-op error),
#              ST_NormalizedDifference (3-arg, 4-arg with nodata), and
#              ST_NormalizedDifferenceStats. Synthetic 2×2 uint8 tiles with
#              band ratios chosen so every expected value is an exact dyadic
#              fraction (no FP noise).
# group: [raquet]

require raquet

# =============================================================================
# Setup: 2×2 uint8 tiles. Two bands per row, each 4 bytes wide.
#   band_a values [3, 6, 9, 12]
#   band_b values [1, 2, 3, 4]
# All ratios a:b = 3:1 → ndiff (a-b)/(a+b) = 0.5 everywhere.
# =============================================================================

statement ok
CREATE TABLE bm_tile AS
SELECT
    '\x03\x06\x09\x0C'::BLOB AS band_a,
    '\x01\x02\x03\x04'::BLOB AS band_b,
    '{"compression":"none","tiling":{"block_width":2,"block_height":2},"bands":[{"name":"band_a","type":"uint8"},{"name":"band_b","type":"uint8"}]}' AS metadata;

# =============================================================================
# ST_BandMath: five operations on uint8 band pairs.
# =============================================================================

query I
SELECT ST_BandMath(band_a, band_b, 'add', metadata) FROM bm_tile;
----
[4.0, 8.0, 12.0, 16.0]

query I
SELECT ST_BandMath(band_a, band_b, 'subtract', metadata) FROM bm_tile;
----
[2.0, 4.0, 6.0, 8.0]

query I
SELECT ST_BandMath(band_a, band_b, 'multiply', metadata) FROM bm_tile;
----
[3.0, 12.0, 27.0, 48.0]

query I
SELECT ST_BandMath(band_a, band_b, 'divide', metadata) FROM bm_tile;
----
[3.0, 3.0, 3.0, 3.0]

query I
SELECT ST_BandMath(band_a, band_b, 'ndiff', metadata) FROM bm_tile;
----
[0.5, 0.5, 0.5, 0.5]

# =============================================================================
# ST_BandMath: short operator aliases match the long names.
# =============================================================================

query I
SELECT ST_BandMath(band_a, band_b, '+', metadata) = ST_BandMath(band_a, band_b, 'add', metadata) FROM bm_tile;
----
true

query I
SELECT ST_BandMath(band_a, band_b, '-', metadata) = ST_BandMath(band_a, band_b, 'subtract', metadata) FROM bm_tile;
----
true

query I
SELECT ST_BandMath(band_a, band_b, '*', metadata) = ST_BandMath(band_a, band_b, 'multiply', metadata) FROM bm_tile;
----
true

query I
SELECT ST_BandMath(band_a, band_b, '/', metadata) = ST_BandMath(band_a, band_b, 'divide', metadata) FROM bm_tile;
----
true

query I
SELECT ST_BandMath(band_a, band_b, 'normalized_difference', metadata) = ST_BandMath(band_a, band_b, 'ndiff', metadata) FROM bm_tile;
----
true

# =============================================================================
# ST_BandMath: unknown operation → propagates as a SQL error (the inner
# InvalidInputException is rethrown wrapped as "ST_BandMath error: ...").
# =============================================================================

statement error
SELECT ST_BandMath(band_a, band_b, 'modulo', metadata) FROM bm_tile;
----
Unknown operation 'modulo'

# =============================================================================
# ST_BandMath: divide by zero produces NaN (per the dedicated divide branch in
# src/raster/band_math.cpp). Use a second tile where band_b has a zero pixel.
# =============================================================================

statement ok
CREATE TABLE bm_tile_zero AS
SELECT
    '\x03\x06\x09\x0C'::BLOB AS band_a,
    '\x01\x00\x03\x04'::BLOB AS band_b,
    '{"compression":"none","tiling":{"block_width":2,"block_height":2},"bands":[{"name":"band_a","type":"uint8"},{"name":"band_b","type":"uint8"}]}' AS metadata;

# Pixel index 1 (band_b=0) is NaN; the other three are 3.0.
query III
SELECT isnan(ST_BandMath(band_a, band_b, 'divide', metadata)[2]),
       ST_BandMath(band_a, band_b, 'divide', metadata)[1],
       ST_BandMath(band_a, band_b, 'divide', metadata)[3]
FROM bm_tile_zero;
----
true	3.0	3.0

# =============================================================================
# ST_NormalizedDifference: 3-arg form matches ST_BandMath('ndiff').
# =============================================================================

query I
SELECT ST_NormalizedDifference(band_a, band_b, metadata) FROM bm_tile;
----
[0.5, 0.5, 0.5, 0.5]

query I
SELECT ST_NormalizedDifference(band_a, band_b, metadata) = ST_BandMath(band_a, band_b, 'ndiff', metadata) FROM bm_tile;
----
true

# =============================================================================
# ST_NormalizedDifference with nodata: any pixel where val1 OR val2 equals the
# nodata sentinel produces the nodata value in the output (not the ndiff).
# band_b has a 2 at pixel index 1; with nodata=2.0 that pixel becomes 2.0.
# =============================================================================

query I
SELECT ST_NormalizedDifference(band_a, band_b, metadata, 2.0) FROM bm_tile;
----
[0.5, 2.0, 0.5, 0.5]

# =============================================================================
# ST_NormalizedDifference: sum==0 short-circuits to 0.0 (no NaN). Use a tile
# where one pixel has both bands at 0.
# =============================================================================

statement ok
CREATE TABLE bm_tile_sumzero AS
SELECT
    '\x03\x00\x09\x0C'::BLOB AS band_a,
    '\x01\x00\x03\x04'::BLOB AS band_b,
    '{"compression":"none","tiling":{"block_width":2,"block_height":2},"bands":[{"name":"band_a","type":"uint8"},{"name":"band_b","type":"uint8"}]}' AS metadata;

query I
SELECT ST_NormalizedDifference(band_a, band_b, metadata)[2] FROM bm_tile_sumzero;
----
0.0

# =============================================================================
# ST_NormalizedDifferenceStats: Welford's-algorithm stats over the ndiff
# result. Primary tile gives every pixel = 0.5 → count=4, sum=2.0, mean=0.5,
# min=max=0.5, stddev=0.0.
# =============================================================================

query IIIIII
SELECT (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).count,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).sum,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).mean,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).min,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).max,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).stddev
FROM bm_tile;
----
4	2.0	0.5	0.5	0.5	0.0

# =============================================================================
# ST_NormalizedDifferenceStats: non-trivial stddev. With band_b=[1,0,3,4] the
# ndiff values are [0.5, 1.0, 0.5, 0.5] → mean=0.625, variance via Welford
# divided by (n-1)=3 gives stddev=0.25 exactly.
# =============================================================================

query IIIIII
SELECT (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).count,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).sum,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).mean,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).min,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).max,
       (ST_NormalizedDifferenceStats(band_a, band_b, metadata)).stddev
FROM bm_tile_zero;
----
4	2.5	0.625	0.5	1.0	0.25
